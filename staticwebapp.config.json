{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["*.css", "*.js", "*.png", "*.jpg", "*.jpeg", "*.svg", "*.webp", "*.avif", "*.xml", "*.ico", "*.woff", "*.woff2", "*.webmanifest"]
  },
  "mimeTypes": {
    ".xml": "application/xml"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
